# Environment variable configuration for Accordis server and inference script.
IMAGE_NAME=<IMAGE_NAME>

# LLM provider selection
# Set to: openai or gemini
PROVIDER=openai

# Model configuration
# OpenAI examples: gpt-4o, gpt-4.1-mini
# Hugging Face examples: Qwen/Qwen2.5-72B-Instruct
# Gemini examples: gemini-2.0-flash, gemini-1.5-pro
MODEL=Qwen/Qwen2.5-72B-Instruct

# API credentials
# Use API_KEY for either OpenAI or Gemini.
# HF_TOKEN is also supported by the current client code for Hugging Face models.
API_KEY=<API_KEY>
HF_TOKEN=<HF_TOKEN>

GEMINI_API_KEY_1=<GEMINI_API_KEY_1>
GEMINI_API_KEY_2=<GEMINI_API_KEY_2>
GEMINI_API_KEY_3=<GEMINI_API_KEY_3>

# Optional base URL override for openai provider.
# Leave as-is for OpenAI. Change this only if you are routing through another compatible endpoint.
API_BASE_URL=https://router.huggingface.co/v1

# Accordis runtime settings
ACCORDIS_ADAPTER=simulated
ACCORDIS_TASKS=easy,medium,hard
ACCORDIS_MAX_STEPS=150
